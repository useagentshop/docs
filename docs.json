{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentShop",
  "description": "AgentShop documentation — headless SEO, structured data, and AI commerce readiness for Shopify storefronts.",
  "colors": {
    "primary": "#0E4D92",
    "light": "#3B82F6",
    "dark": "#0A3D7A"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "pages": [
      "index",
      {
        "group": "Headless SEO SDK",
        "pages": [
          "sdk/overview",
          "sdk/quickstart",
          "sdk/concepts"
        ]
      },
      {
        "group": "Framework guides",
        "pages": [
          "sdk/next-app-router",
          "sdk/next-pages-router",
          "sdk/remix",
          "sdk/hydrogen"
        ]
      },
      {
        "group": "Artifacts",
        "pages": [
          "sdk/product",
          "sdk/collection",
          "sdk/site",
          "sdk/sitemap"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "sdk/reference/config",
          "sdk/reference/core",
          "sdk/reference/next",
          "sdk/reference/endpoints"
        ]
      },
      {
        "group": "Security & troubleshooting",
        "pages": [
          "sdk/security",
          "sdk/troubleshooting"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://useagentshop.com",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@useagentshop.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.useagentshop.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
